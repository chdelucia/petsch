{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@petsch/api": ["libs/product/api/src/index.ts"],
      "@petsch/data-access": ["libs/product/data-access/src/index.ts"],
      "@petsch/shell": ["libs/product/shell/src/index.ts"],
      "@petsch/feature-product-list": [
        "libs/product/feature-product-list/src/index.ts"
      ]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
