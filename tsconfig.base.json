{
  "compileOnSave": false,
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@petsch/api": ["libs/products/api/src/index.ts"],
      "@petsch/data-access": ["libs/products/data-access/src/index.ts"],
      "@petsch/shell": ["libs/products/shell/src/index.ts"],
      "@petsch/feature-product-list": ["libs/products/feature-product-list/src/index.ts"],
      "@petsch/feature-product-details": [
        "libs/products/feature-product-details/src/index.ts"
      ],
      "@petsch/obs-api": ["libs/shared/observability/api/src/index.ts"],
      "@petsch/obs-data-access": [
        "libs/shared/observability/data-access/src/index.ts"
      ],
      "@petsch/ui": ["libs/shared/ui/src/index.ts"],
      "@petsch/shared-utils": ["libs/shared/utils/src/index.ts"],
      "@petsch/feature-item-of-day": [
        "libs/products/feature-item-of-day/src/index.ts"
      ],
      "@petsch/feature-page": ["libs/products/feature-page/src/index.ts"],
      "@petsch/feature-filters": ["libs/products/feature-filters/src/index.ts"],
      "@petsch/feature-404": ["libs/shared/feature-404/src/index.ts"],
      "@petsch/api-petshop": ["libs/products/api-petshop/src/index.ts"],
      "@petsch/api-rickymorty": ["libs/products/api-rickymorty/src/index.ts"],
      "@petsch/api-dragonball": ["libs/products/api-dragonball/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
