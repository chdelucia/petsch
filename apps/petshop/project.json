{
  "name": "petshop",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/petshop/src",
  "tags": ["scope:petshop", "type:main"],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "syncGenerators": ["@juristr/nx-tailwind-sync:source-directives"],
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/petshop",
        "browser": "apps/petshop/src/main.ts",
        "tsConfig": "apps/petshop/tsconfig.app.json",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/petshop/public"
          }
        ],
        "styles": ["apps/petshop/src/styles.css"]
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "20kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "syncGenerators": ["@juristr/nx-tailwind-sync:source-directives"],
      "configurations": {
        "production": {
          "buildTarget": "petshop:build:production"
        },
        "development": {
          "buildTarget": "petshop:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@angular/build:unit-test",
      "options": {}
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "petshop:build",
        "port": 4200,
        "staticFilePath": "dist/apps/petshop/browser",
        "spa": true
      }
    }
  }
}
